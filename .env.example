# OpenAI API Key for AI CLI
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI-compatible Custom API Base URL (e.g. OpenRouter, DeepSeek, Local LLMs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default Model (optional, defaults to gpt-4o or gpt-3.5-turbo if not specified)
# Supported models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o
